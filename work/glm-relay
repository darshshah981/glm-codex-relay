    return TRACE_DIR / "runs"


def trace_run_dirs():
    root = trace_runs_root()
    if not root.exists():
        return []
    return sorted(
        [path for path in root.iterdir() if path.is_dir()],
        key=lambda path: (path.stat().st_mtime, path.name),
