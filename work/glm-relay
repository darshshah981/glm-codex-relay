def git_command(cwd, *args):
    return subprocess.run(
        ["git", "-C", str(cwd), *args],
        text=True,
        capture_output=True,
        timeout=GIT_COMMAND_TIMEOUT_SECONDS,
    )


def unavailable_git_context(reason):
    return {
        "available": False,
        "reason": as_text(reason).strip()[:500],
        "repo_root": "",
        "head": "",
        "status": [],
    }


def parse_git_status_lines(text):
    entries = []
    for line in as_text(text).splitlines():
        if not line:
            continue
        status = line[:2].strip() or line[:2]
        path = line[3:] if len(line) > 3 else ""
        entries.append({"status": status, "path": path})
    return entries


def git_context(cwd):
    cwd = Path(cwd)
    if not cwd.exists() or not cwd.is_dir():
        return unavailable_git_context(f"cwd is not a directory: {cwd}")

    try:
        root = git_command(cwd, "rev-parse", "--show-toplevel")
        if root.returncode != 0:
            return unavailable_git_context(root.stderr or root.stdout or "not a git repository")
        head = git_command(cwd, "rev-parse", "HEAD")
        status = git_command(cwd, "status", "--porcelain=v1")
    except FileNotFoundError:
        return unavailable_git_context("git binary not found")
    except subprocess.TimeoutExpired as exc:
        return unavailable_git_context(f"git command timed out after {exc.timeout}s")
    except Exception as exc:
        return unavailable_git_context(exc)

    if head.returncode != 0:
        return unavailable_git_context(head.stderr or head.stdout or "cannot resolve git HEAD")
    if status.returncode != 0:
        return unavailable_git_context(status.stderr or status.stdout or "cannot read git status")

    return {
        "available": True,
        "reason": "",
        "repo_root": root.stdout.strip(),
        "head": head.stdout.strip(),
        "status": parse_git_status_lines(status.stdout),
    }


def git_status_map(snapshot):
    return {
        entry.get("path", ""): entry.get("status", "")
        for entry in snapshot.get("status", [])
        if entry.get("path")
    }


def git_status_delta(before, after):
    if not before.get("available") or not after.get("available"):
        return []

    before_status = git_status_map(before)
    after_status = git_status_map(after)
    changed = []
    for path in sorted(set(before_status) | set(after_status)):
        before_value = before_status.get(path, "")
        after_value = after_status.get(path, "")
        if before_value == after_value and after_value:
            change = "preexisting"
        elif before_value and not after_value:
            change = "cleaned"
        elif after_value and not before_value:
            change = "new"
        else:
            change = "changed"
        changed.append({
            "path": path,
            "before_status": before_value,
            "after_status": after_value,
            "change": change,
        })
    return changed


def worker_run_dirs():
    if not WORKER_RUNS.exists():
        return []
    return sorted(
        [path for path in WORKER_RUNS.iterdir() if path.is_dir()],
        key=lambda path: (path.stat().st_mtime, path.name),
    )


def resolve_worker_run(target):
    target = target or "latest"
    if target == "latest":
        runs = worker_run_dirs()
        if not runs:
            raise SystemExit(f"no worker runs found under {WORKER_RUNS}")
        return runs[-1]

    explicit = Path(target).expanduser()
    candidates = []
    if explicit.exists():
        candidates.append(explicit)
    if not explicit.is_absolute():
        candidates.append(WORKER_RUNS / target)
        candidates.extend(run for run in worker_run_dirs() if run.name == target)

    for candidate in candidates:
        if candidate.exists() and candidate.is_dir():
            return candidate.resolve()
        if candidate.exists():
            raise SystemExit(f"worker run target is not a directory: {candidate}")

    raise SystemExit(f"worker run not found: {target}")


def read_artifact_text(path, warnings):
    if not path.exists():
        warnings.append(f"missing artifact: {path.name}")
        return ""
    try:
        return path.read_text(encoding="utf-8", errors="replace")
    except Exception as exc:
        warnings.append(f"cannot read {path.name}: {exc}")
        return ""


def read_artifact_json(path, warnings):
    text = read_artifact_text(path, warnings)
    if not text:
        return {}
    try:
        payload = json.loads(text)
    except json.JSONDecodeError as exc:
        warnings.append(f"malformed JSON in {path.name}: {exc}")
        return {}
    if not isinstance(payload, dict):
        warnings.append(f"unexpected JSON shape in {path.name}: expected object")
        return {}
    return payload


def load_worker_run(target):
    run_dir = resolve_worker_run(target)
    warnings = []
    metadata = read_artifact_json(run_dir / "metadata.json", warnings)
    stdout = read_artifact_text(run_dir / "stdout.txt", warnings)
    stderr = read_artifact_text(run_dir / "stderr.txt", warnings)
    exit_code_text = read_artifact_text(run_dir / "exit_code.txt", warnings)
    summary = read_artifact_text(run_dir / "summary.txt", warnings)
    return {
        "run_dir": run_dir,
        "metadata": metadata,
        "stdout": stdout,
        "stderr": stderr,
        "exit_code_text": exit_code_text,
        "summary": summary,
        "warnings": warnings,
    }


def parse_exit_code(bundle, warnings):
    metadata_exit = bundle["metadata"].get("exit_code")
    if isinstance(metadata_exit, int):
        return metadata_exit
    try:
        return int(bundle["exit_code_text"].strip())
    except (TypeError, ValueError):
        warnings.append("missing or invalid exit code")
        return None


def safe_review_metadata(metadata):
    allowed = [
        "model",
        "codex_profile",
        "codex_home",
        "profile_output",
        "cwd",
        "port",
        "pid",
        "started_at",
        "ended_at",
        "elapsed_seconds",
        "argv",
        "exit_code",
        "error",
        "relay_log",
        "tool_denylist",
        "git",
    ]
    safe = {key: metadata[key] for key in allowed if key in metadata}
    argv = safe.get("argv")
    if isinstance(argv, list) and argv:
        safe["argv"] = list(argv[:-1]) + ["<redacted-task-prompt>"]
    return safe


def tail_lines(text, limit):
    if limit <= 0:
        return []
    lines = as_text(text).splitlines()
    if len(lines) <= limit:
        return lines
    return lines[-limit:]


def changed_files_from_metadata(metadata, warnings):
    git = metadata.get("git")
    if not isinstance(git, dict):
        warnings.append("metadata has no git context; changed files unknown")
        return []

    before = git.get("before")
    after = git.get("after")
    changed = git.get("changed_files")
    if isinstance(changed, list):
        if changed:
            return changed
        if isinstance(before, dict) and isinstance(after, dict):
            if before.get("available") and after.get("available"):
                return []
            reason = after.get("reason") or before.get("reason") or "git context unavailable"
            warnings.append(f"git context unavailable: {reason}")
            return []
        warnings.append("metadata git context is incomplete; changed files unknown")
        return []

    if isinstance(before, dict) and isinstance(after, dict):
        delta = git_status_delta(before, after)
        if delta:
            return delta
        if before.get("available") and after.get("available"):
            return []
        reason = after.get("reason") or before.get("reason") or "git context unavailable"
        warnings.append(f"git context unavailable: {reason}")
        return []

    warnings.append("metadata git context is incomplete; changed files unknown")
    return []


def build_worker_review(bundle, stdout_lines=DEFAULT_REVIEW_TAIL_LINES, stderr_lines=DEFAULT_REVIEW_TAIL_LINES):
    warnings = list(bundle["warnings"])
    metadata = safe_review_metadata(bundle["metadata"])
    exit_code = parse_exit_code(bundle, warnings)
    changed_files = changed_files_from_metadata(metadata, warnings)
    status = "unknown"
    if exit_code is not None:
        status = "passed" if exit_code == 0 else "failed"

    return {
        "run_dir": str(bundle["run_dir"]),
        "status": status,
        "exit_code": exit_code,
        "model": metadata.get("model", ""),
        "elapsed_seconds": metadata.get("elapsed_seconds"),
        "cwd": metadata.get("cwd", ""),
        "relay_pid": metadata.get("pid"),
        "metadata": metadata,
        "changed_files": changed_files,
        "warnings": warnings,
        "stdout_tail": tail_lines(bundle["stdout"], stdout_lines),
        "stderr_tail": tail_lines(bundle["stderr"], stderr_lines),
    }


def format_changed_file(change):
    if isinstance(change, str):
        return change
    path = change.get("path", "")
    label = change.get("change", "changed")
    before = change.get("before_status", "")
    after = change.get("after_status", "")
    status = f"{before or '-'} -> {after or '-'}"
    return f"{path} ({label}, {status})"


def format_worker_review(review):
    exit_code = "unknown" if review["exit_code"] is None else str(review["exit_code"])
    lines = [
        f"worker review: {review['status']} exit_code={exit_code}",
        f"artifacts={review['run_dir']}",
        f"model={review['model'] or 'unknown'}",
        f"elapsed_seconds={review['elapsed_seconds'] if review['elapsed_seconds'] is not None else 'unknown'}",
        f"cwd={review['cwd'] or 'unknown'}",
        f"relay_pid={review['relay_pid'] if review['relay_pid'] is not None else 'unknown'}",
    ]

    if review["changed_files"]:
        lines.append("changed_files:")
        lines.extend(f"  - {format_changed_file(change)}" for change in review["changed_files"])
    else:
        lines.append("changed_files=unknown_or_none")

    if review["warnings"]:
        lines.append("warnings:")
        lines.extend(f"  - {warning}" for warning in review["warnings"])

    if review["stdout_tail"]:
        lines.append("stdout_tail:")
        lines.extend(f"  {line}" for line in review["stdout_tail"])

    if review["stderr_tail"]:
        lines.append("stderr_tail:")
        lines.extend(f"  {line}" for line in review["stderr_tail"])

    lines.append("review: inspect the actual git diff and relevant tests before trusting GLM output")
    lines.append("")
    return "\n".join(lines)


def review_worker(args):
    bundle = load_worker_run(args.target)
    review = build_worker_review(
        bundle,
        stdout_lines=args.stdout_lines,
        stderr_lines=args.stderr_lines,
    )
    if args.json_output:
        print(json.dumps(review, indent=2, sort_keys=True))
    else:
        print(format_worker_review(review), end="")
    return 0


def worker_env(codex_home):
    env = os.environ.copy()
    env["CODEX_HOME"] = str(codex_home)
    scrub_relay_secret_env(env)
    return env


def scrub_relay_secret_env(env):
    for key in list(env):
        if key.startswith("ZAI_") or key.startswith("CODEX_RELAY_"):
            env.pop(key, None)
    return env


def codex_home_path(value):
    return Path(value).expanduser().resolve()


def profile_path_for_codex_home(codex_home, profile_name):
    return codex_home / f"{profile_name}.config.toml"


def pid_from_file():
    try:
        return int(PID_FILE.read_text(encoding="utf-8").strip())
    except Exception:
        return None


def process_alive(pid):
    if not pid:
        return False
    try:
        os.kill(pid, 0)
        return True
    except ProcessLookupError:
        return False
    except PermissionError:
        return True


def relay_is_running():
    pid = pid_from_file()
    return pid if process_alive(pid) else None


def stop_relay():
    pid = relay_is_running()
    if not pid:
        PID_FILE.unlink(missing_ok=True)
        return False
    os.kill(pid, signal.SIGTERM)
    deadline = time.time() + 10
    while time.time() < deadline:
        if not process_alive(pid):
            break
        time.sleep(0.2)
    if process_alive(pid):
        os.kill(pid, signal.SIGKILL)
    PID_FILE.unlink(missing_ok=True)
    return True


def start_relay(args):
    ensure_dirs()
    if relay_is_running():
        if args.restart:
            stop_relay()
        else:
            raise SystemExit(f"relay already running with pid {pid_from_file()}")

    raw_key = os.environ.get("ZAI_RAW_KEY", "")
    token, exp = generate_zai_jwt(raw_key, ttl_seconds=args.jwt_ttl_seconds)
    relay_bin = find_relay_binary()

    env = scrub_relay_secret_env(os.environ.copy())
    env["CODEX_RELAY_UPSTREAM"] = args.upstream
    env["CODEX_RELAY_API_KEY"] = token
    env["CODEX_RELAY_PORT"] = str(args.port)
    env["CODEX_RELAY_TOOL_DENYLIST"] = args.tool_denylist
    env["CODEX_RELAY_HISTORY_STORE"] = args.history_store
    env["CODEX_RELAY_HISTORY_DIR"] = str(STATE / "history")
    env["RUST_LOG"] = args.log_level

    if args.model_map:
        env["CODEX_RELAY_MODEL_MAP"] = args.model_map
    if args.upstream_extra_params:
        env["CODEX_RELAY_UPSTREAM_EXTRA_PARAMS"] = args.upstream_extra_params
    if args.drop_upstream_params:
        env["CODEX_RELAY_DROP_PARAMS"] = args.drop_upstream_params

    log = LOG_FILE.open("ab")
    log.write(f"\n--- glm-relay start {time.strftime('%Y-%m-%dT%H:%M:%SZ', time.gmtime())} ---\n".encode())
    log.flush()
    proc = subprocess.Popen(
        [relay_bin],
        cwd=str(ROOT),
        env=env,
        stdout=log,
        stderr=subprocess.STDOUT,
        start_new_session=True,
    )
    PID_FILE.write_text(str(proc.pid), encoding="utf-8")
    save_state({
        "pid": proc.pid,
        "port": args.port,
        "upstream": args.upstream,
        "model": args.model,
        "jwt_expires_at": exp,
        "jwt_refresh_margin_seconds": args.refresh_margin_seconds,
        "relay_bin": relay_bin,
        "log_file": str(LOG_FILE),
        "started_at": int(time.time()),
        "tool_denylist": args.tool_denylist,
        "history_store": args.history_store,
        "model_map": args.model_map,
        "upstream_extra_params": args.upstream_extra_params,
        "drop_upstream_params": args.drop_upstream_params,
    })
    print(f"started codex-relay pid={proc.pid} on http://127.0.0.1:{args.port}/v1")
    print(f"jwt expires at {time.strftime('%Y-%m-%dT%H:%M:%SZ', time.gmtime(exp))}")


def restart_if_needed(args):
    state = load_state()
    pid = relay_is_running()
    if not pid:
        print("relay not running; starting")
        start_relay(args)
        return
    mismatches = relay_state_mismatches(state, args)
    if mismatches:
        print(f"relay settings changed ({', '.join(mismatches)}); restarting relay")
        stop_relay()
        start_relay(args)
        return
    exp = int(state.get("jwt_expires_at", 0))
    margin = int(state.get("jwt_refresh_margin_seconds", args.refresh_margin_seconds))
    if exp and time.time() < exp - margin:
        remaining = int(exp - time.time())
        print(f"relay ok pid={pid}; jwt has {remaining}s remaining")
        return
    print("jwt near expiry or unknown; restarting relay with fresh token")
    stop_relay()
    start_relay(args)


def relay_state_mismatches(state, args):
    expected = {
        "port": args.port,
        "upstream": args.upstream,
        "model": args.model,
        "tool_denylist": args.tool_denylist,
        "history_store": args.history_store,
        "model_map": args.model_map,
        "upstream_extra_params": args.upstream_extra_params,
        "drop_upstream_params": args.drop_upstream_params,
    }
    mismatches = []
    for key, expected_value in expected.items():
        actual = state.get(key)
        if actual is None and expected_value == "":
            actual = ""
        if actual != expected_value:
            mismatches.append(key)
    return mismatches


def serve(args):
    print("serving GLM relay; press Ctrl-C to stop")
    try:
        while True:
            restart_if_needed(args)
            time.sleep(args.check_interval_seconds)
    except KeyboardInterrupt:
        print("\nshutting down relay")
        stop_relay()


def status(_args):
    state = load_state()
    pid = relay_is_running()
    if not pid:
        print("stopped")
        return 1
    exp = int(state.get("jwt_expires_at", 0))
    remaining = max(0, int(exp - time.time())) if exp else None
    print(f"running pid={pid}")
    print(f"url=http://127.0.0.1:{state.get('port', DEFAULT_PORT)}/v1")
    print(f"upstream={state.get('upstream', DEFAULT_UPSTREAM)}")
    print(f"log={state.get('log_file', str(LOG_FILE))}")
    if remaining is not None:
        print(f"jwt_remaining_seconds={remaining}")
    return 0


def install_relay(args):
    ensure_dirs()
    python = args.python or sys.executable
    venv = WORK / ".venv"
    if not (venv / "bin" / "python").exists():
        subprocess.check_call([python, "-m", "venv", str(venv)])
    pip = venv / "bin" / "python"
    subprocess.check_call([str(pip), "-m", "pip", "install", "-U", "pip"])

    source = args.source
    if source == "auto":
        has_vendored = (VENDORED_RELAY / "pyproject.toml").exists()
        has_rust = shutil.which("cargo") and shutil.which("rustc")
        source = "vendored" if has_vendored and has_rust else "pypi"

    if source == "vendored":
        if not (VENDORED_RELAY / "pyproject.toml").exists():
            raise SystemExit(f"vendored codex-relay source not found: {VENDORED_RELAY}")
        subprocess.check_call([str(pip), "-m", "pip", "install", "-U", str(VENDORED_RELAY)])
    else:
        subprocess.check_call([str(pip), "-m", "pip", "install", "-U", "codex-relay"])

    print(venv / "bin" / "codex-relay")


