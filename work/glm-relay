def b64url(data):
    if not isinstance(data, bytes):
        data = json.dumps(data, separators=(",", ":")).encode("utf-8")
    return base64.urlsafe_b64encode(data).rstrip(b"=").decode("ascii")


def ensure_dirs():
    STATE.mkdir(parents=True, exist_ok=True)
    OUT.mkdir(parents=True, exist_ok=True)


def load_state():
    if not STATE_FILE.exists():
        return {}
    try:
        return json.loads(STATE_FILE.read_text(encoding="utf-8"))
    except Exception:
        return {}


def save_state(state):
    ensure_dirs()
    STATE_FILE.write_text(json.dumps(state, indent=2, sort_keys=True), encoding="utf-8")


def generate_zai_jwt(raw_key, ttl_seconds=3600):
    raw_key = raw_key.strip()
    if "." not in raw_key:
        raise SystemExit("ZAI_RAW_KEY must be set to the Z.ai api_id.secret value")
    api_id, secret = raw_key.split(".", 1)
    if not api_id or not secret:
        raise SystemExit("ZAI_RAW_KEY is malformed; expected api_id.secret")

    now_ms = int(time.time() * 1000)
    exp_ms = now_ms + ttl_seconds * 1000
    header = {"alg": "HS256", "sign_type": "SIGN"}
    payload = {"api_key": api_id, "exp": exp_ms, "timestamp": now_ms}
    message = f"{b64url(header)}.{b64url(payload)}".encode("ascii")
    signature = hmac.new(secret.encode("utf-8"), message, hashlib.sha256).digest()
    return f"{message.decode('ascii')}.{b64url(signature)}", exp_ms // 1000


def find_relay_binary():
    explicit = os.environ.get("CODEX_RELAY_BIN")
    if explicit:
        path = Path(explicit).expanduser()
        if path.exists():
            return str(path)
        raise SystemExit(f"CODEX_RELAY_BIN is set but not found: {path}")

    path = shutil.which("codex-relay")
    if path:
        return path

    venv_path = WORK / ".venv" / "bin" / "codex-relay"
    if venv_path.exists():
        return str(venv_path)

    raise SystemExit(
        "codex-relay binary not found. Run: work/glm-relay install-relay"
    )


def find_codex_binary():
    explicit = os.environ.get("CODEX_BIN")
    if explicit:
        path = Path(explicit).expanduser()
        if path.exists():
            return str(path)
        resolved = shutil.which(explicit)
        if resolved:
            return resolved
        raise SystemExit(f"CODEX_BIN is set but not found: {explicit}")

    path = shutil.which("codex")
    if path:
        return path

    raise SystemExit("codex CLI not found. Install Codex or set CODEX_BIN.")


def safe_slug(text, fallback="worker"):
    slug = re.sub(r"[^a-z0-9]+", "-", text.lower()).strip("-")
    slug = re.sub(r"-{2,}", "-", slug)
    return (slug or fallback)[:48].strip("-") or fallback


def unique_worker_run_dir(task, label=""):
    ensure_dirs()
    WORKER_RUNS.mkdir(parents=True, exist_ok=True)
    stamp = time.strftime("%Y%m%d-%H%M%S", time.localtime())
    base = f"{stamp}-{safe_slug(label or task)}"
    candidate = WORKER_RUNS / base
    suffix = 2
    while candidate.exists():
        candidate = WORKER_RUNS / f"{base}-{suffix}"
        suffix += 1
    candidate.mkdir(parents=True)
    return candidate


def write_json(path, payload):
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(payload, indent=2, sort_keys=True), encoding="utf-8")


def write_worker_text(path, text):
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(as_text(text), encoding="utf-8")


def as_text(value):
    if value is None:
        return ""
    if isinstance(value, bytes):
        return value.decode("utf-8", errors="replace")
    return str(value)


def worker_summary(metadata, run_dir):
    status = "passed" if metadata["exit_code"] == 0 else "failed"
    return "\n".join([
        f"worker {status}: exit_code={metadata['exit_code']}",
        f"elapsed_seconds={metadata['elapsed_seconds']:.2f}",
        f"artifacts={run_dir}",
        "review: inspect stdout.txt, stderr.txt, metadata.json, and git diff before trusting GLM output",
        "",
    ])


def worker_env(codex_home):
    env = os.environ.copy()
    env["CODEX_HOME"] = str(codex_home)
    for key in list(env):
        if key.startswith("ZAI_") or key.startswith("CODEX_RELAY_"):
            env.pop(key, None)
    return env


def codex_home_path(value):
    return Path(value).expanduser().resolve()


def profile_path_for_codex_home(codex_home, profile_name):
    return codex_home / f"{profile_name}.config.toml"


def pid_from_file():
    try:
        return int(PID_FILE.read_text(encoding="utf-8").strip())
    except Exception:
        return None


def process_alive(pid):
    if not pid:
        return False
    try:
        os.kill(pid, 0)
        return True
    except ProcessLookupError:
        return False
    except PermissionError:
        return True


def relay_is_running():
    pid = pid_from_file()
    return pid if process_alive(pid) else None


def stop_relay():
    pid = relay_is_running()
    if not pid:
        PID_FILE.unlink(missing_ok=True)
        return False
    os.kill(pid, signal.SIGTERM)
    deadline = time.time() + 10
    while time.time() < deadline:
        if not process_alive(pid):
            break
        time.sleep(0.2)
    if process_alive(pid):
        os.kill(pid, signal.SIGKILL)
    PID_FILE.unlink(missing_ok=True)
    return True


def start_relay(args):
    ensure_dirs()
    if relay_is_running():
        if args.restart:
            stop_relay()
        else:
            raise SystemExit(f"relay already running with pid {pid_from_file()}")

    raw_key = os.environ.get("ZAI_RAW_KEY", "")
    token, exp = generate_zai_jwt(raw_key, ttl_seconds=args.jwt_ttl_seconds)
    relay_bin = find_relay_binary()

    env = os.environ.copy()
    env["CODEX_RELAY_UPSTREAM"] = args.upstream
    env["CODEX_RELAY_API_KEY"] = token
    env["CODEX_RELAY_PORT"] = str(args.port)
    env["CODEX_RELAY_TOOL_DENYLIST"] = args.tool_denylist
    env["CODEX_RELAY_HISTORY_STORE"] = args.history_store
    env["CODEX_RELAY_HISTORY_DIR"] = str(STATE / "history")
    env["RUST_LOG"] = args.log_level

    if args.model_map:
        env["CODEX_RELAY_MODEL_MAP"] = args.model_map
    if args.upstream_extra_params:
        env["CODEX_RELAY_UPSTREAM_EXTRA_PARAMS"] = args.upstream_extra_params
    if args.drop_upstream_params:
        env["CODEX_RELAY_DROP_PARAMS"] = args.drop_upstream_params

    log = LOG_FILE.open("ab")
    log.write(f"\n--- glm-relay start {time.strftime('%Y-%m-%dT%H:%M:%SZ', time.gmtime())} ---\n".encode())
    log.flush()
    proc = subprocess.Popen(
        [relay_bin],
        cwd=str(ROOT),
        env=env,
        stdout=log,
        stderr=subprocess.STDOUT,
        start_new_session=True,
    )
    PID_FILE.write_text(str(proc.pid), encoding="utf-8")
    save_state({
        "pid": proc.pid,
        "port": args.port,
        "upstream": args.upstream,
        "model": args.model,
        "jwt_expires_at": exp,
        "jwt_refresh_margin_seconds": args.refresh_margin_seconds,
        "relay_bin": relay_bin,
        "log_file": str(LOG_FILE),
        "started_at": int(time.time()),
        "tool_denylist": args.tool_denylist,
        "history_store": args.history_store,
        "model_map": args.model_map,
        "upstream_extra_params": args.upstream_extra_params,
        "drop_upstream_params": args.drop_upstream_params,
    })
    print(f"started codex-relay pid={proc.pid} on http://127.0.0.1:{args.port}/v1")
    print(f"jwt expires at {time.strftime('%Y-%m-%dT%H:%M:%SZ', time.gmtime(exp))}")


def restart_if_needed(args):
    state = load_state()
    pid = relay_is_running()
    if not pid:
        print("relay not running; starting")
        start_relay(args)
        return
    mismatches = relay_state_mismatches(state, args)
    if mismatches:
        print(f"relay settings changed ({', '.join(mismatches)}); restarting relay")
        stop_relay()
        start_relay(args)
        return
    exp = int(state.get("jwt_expires_at", 0))
    margin = int(state.get("jwt_refresh_margin_seconds", args.refresh_margin_seconds))
    if exp and time.time() < exp - margin:
        remaining = int(exp - time.time())
        print(f"relay ok pid={pid}; jwt has {remaining}s remaining")
        return
    print("jwt near expiry or unknown; restarting relay with fresh token")
    stop_relay()
    start_relay(args)


def relay_state_mismatches(state, args):
    expected = {
        "port": args.port,
        "upstream": args.upstream,
        "model": args.model,
        "tool_denylist": args.tool_denylist,
        "history_store": args.history_store,
        "model_map": args.model_map,
        "upstream_extra_params": args.upstream_extra_params,
        "drop_upstream_params": args.drop_upstream_params,
    }
    mismatches = []
    for key, expected_value in expected.items():
        actual = state.get(key)
        if actual is None and expected_value == "":
            actual = ""
        if actual != expected_value:
            mismatches.append(key)
    return mismatches


def serve(args):
    print("serving GLM relay; press Ctrl-C to stop")
    try:
        while True:
            restart_if_needed(args)
            time.sleep(args.check_interval_seconds)
    except KeyboardInterrupt:
        print("\nshutting down relay")
        stop_relay()


def status(_args):
    state = load_state()
    pid = relay_is_running()
    if not pid:
        print("stopped")
        return 1
    exp = int(state.get("jwt_expires_at", 0))
    remaining = max(0, int(exp - time.time())) if exp else None
    print(f"running pid={pid}")
    print(f"url=http://127.0.0.1:{state.get('port', DEFAULT_PORT)}/v1")
    print(f"upstream={state.get('upstream', DEFAULT_UPSTREAM)}")
    print(f"log={state.get('log_file', str(LOG_FILE))}")
    if remaining is not None:
        print(f"jwt_remaining_seconds={remaining}")
    return 0


def install_relay(args):
    ensure_dirs()
    python = args.python or sys.executable
    venv = WORK / ".venv"
    if not (venv / "bin" / "python").exists():
        subprocess.check_call([python, "-m", "venv", str(venv)])
    pip = venv / "bin" / "python"
    subprocess.check_call([str(pip), "-m", "pip", "install", "-U", "pip"])

    source = args.source
    if source == "auto":
        has_vendored = (VENDORED_RELAY / "pyproject.toml").exists()
        has_rust = shutil.which("cargo") and shutil.which("rustc")
        source = "vendored" if has_vendored and has_rust else "pypi"

    if source == "vendored":
        if not (VENDORED_RELAY / "pyproject.toml").exists():
            raise SystemExit(f"vendored codex-relay source not found: {VENDORED_RELAY}")
        subprocess.check_call([str(pip), "-m", "pip", "install", "-U", str(VENDORED_RELAY)])
    else:
        subprocess.check_call([str(pip), "-m", "pip", "install", "-U", "codex-relay"])

    print(venv / "bin" / "codex-relay")


