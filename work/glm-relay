def worker_preflight(args):
    codex_bin = find_codex_binary()
    worker_cwd = Path(args.cwd).expanduser().resolve()
    codex_home = codex_home_path(args.codex_home)
    if not worker_cwd.exists() or not worker_cwd.is_dir():
        raise SystemExit(f"worker cwd is not a directory: {worker_cwd}")

    restart_if_needed(args)
    wait_for_local_port(args.port, min(args.timeout, 10.0))
    write_profile(argparse.Namespace(
        output=str(profile_path_for_codex_home(codex_home, args.codex_profile)),
        port=args.port,
        model=args.model,
    ))
    return codex_bin, worker_cwd, codex_home


def health(args):
    url = f"http://127.0.0.1:{args.port}/v1/models"
    try:
        with urllib.request.urlopen(url, timeout=args.timeout) as resp:
            body = resp.read().decode("utf-8", errors="replace")
            print(f"ok status={resp.status}")
            print(body[:1000])
            return 0
    except Exception as exc:
        print(f"health failed: {exc}")
        return 1


def post_json(url, payload, timeout):
    data = json.dumps(payload).encode("utf-8")
    req = urllib.request.Request(
        url,
        data=data,
        headers={"Content-Type": "application/json"},
        method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            body = resp.read().decode("utf-8", errors="replace")
            return resp.status, json.loads(body)
    except urllib.error.HTTPError as exc:
        body = exc.read().decode("utf-8", errors="replace")
        raise SystemExit(f"live smoke failed: relay returned {exc.code}: {body}") from exc
    except urllib.error.URLError as exc:
        raise SystemExit(f"live smoke failed: cannot reach local relay: {exc}") from exc
    except json.JSONDecodeError as exc:
        raise SystemExit(f"live smoke failed: relay returned non-JSON: {exc}") from exc


def wait_for_local_port(port, timeout):
    deadline = time.time() + timeout
    last_error = None
    while time.time() < deadline:
        try:
            with socket.create_connection(("127.0.0.1", port), timeout=0.2):
                return
        except OSError as exc:
            last_error = exc
            time.sleep(0.1)
    raise SystemExit(f"live smoke failed: relay did not open port {port}: {last_error}")


def extract_output_text(response):
    texts = []
    for item in response.get("output", []):
        if item.get("type") != "message":
            continue
        for part in item.get("content", []):
            if part.get("type") == "output_text" and part.get("text"):
                texts.append(part["text"])
    return "".join(texts)


def output_function_calls(response):
    return [
        item
        for item in response.get("output", [])
        if item.get("type") == "function_call"
    ]


def text_smoke_payload(model):
    return {
        "model": model,
        "instructions": "Reply concisely.",
        "input": "Reply with exactly: GLM_SMOKE_OK",
        "stream": False,
        "temperature": 0,
        "max_output_tokens": 512,
    }


def tool_smoke_payload(model):
    return {
        "model": model,
        "instructions": (
            "You are testing tool-call wiring. Call exec_command exactly once "
            "with cmd set to echo GLM_TOOL_OK. Do not call any other tool."
        ),
        "input": "Use the available tool for the harmless echo check.",
        "tools": [
            {
                "type": "function",
                "name": "exec_command",
                "description": "Run a harmless shell command.",
                "parameters": {
                    "type": "object",
                    "properties": {"cmd": {"type": "string"}},
                    "required": ["cmd"],
                },
            },
            {
                "type": "function",
                "name": "spawn_agent",
                "description": "Denied subagent tool that should not reach GLM.",
                "parameters": {"type": "object"},
            },
        ],
        "stream": False,
        "temperature": 0,
        "max_output_tokens": 512,
    }


def live_smoke(args):
    started_by_smoke = False
    pid = relay_is_running()
    if not pid:
        if not os.environ.get("ZAI_RAW_KEY"):
            raise SystemExit(
                "ZAI_RAW_KEY is required to start the relay for a live smoke. "
                "Set it in this shell, then rerun: work/glm-relay live-smoke"
            )
        start_args = argparse.Namespace(**vars(args))
        start_args.restart = False
        start_args.history_store = "memory"
        start_relay(start_args)
        started_by_smoke = True
        wait_for_local_port(args.port, min(args.timeout, 10.0))
    else:
        print(f"using running relay pid={pid}")

    try:
        state = load_state()
        port = int(state.get("port", args.port))
        url = f"http://127.0.0.1:{port}/v1/responses"

        print("checking text response through live GLM endpoint")
        _status, text_response = post_json(
            url,
            text_smoke_payload(args.model),
            timeout=args.timeout,
        )
        text = extract_output_text(text_response).strip()
        if not text:
            raise SystemExit("live smoke failed: text response contained no output text")
        print(f"text ok: {text[:120]}")

        if args.include_tool_call:
            print("checking optional normal tool-call response")
            _status, tool_response = post_json(
                url,
                tool_smoke_payload(args.model),
                timeout=args.timeout,
            )
            calls = output_function_calls(tool_response)
            denied = [call for call in calls if call.get("name") == "spawn_agent"]
            if denied:
                raise SystemExit("live smoke failed: denied spawn_agent tool was returned")
            exec_calls = [call for call in calls if call.get("name") == "exec_command"]
            if not exec_calls:
                raise SystemExit(
                    "live smoke failed: GLM did not return an exec_command tool call"
                )
            print(f"tool ok: exec_command call_id={exec_calls[0].get('call_id', '')}")

        print("live smoke passed")
        return 0
    finally:
        if started_by_smoke and not args.keep_running:
            stop_relay()
            print("stopped smoke relay")


def run_worker(args):
    run_dir = unique_worker_run_dir(args.task, args.label)
    started_at = time.time()
    write_worker_text(run_dir / "prompt.txt", args.task)

    codex_bin = ""
    worker_cwd = Path(args.cwd).expanduser().resolve()
    codex_home = codex_home_path(args.codex_home)
    stdout = ""
    stderr = ""
    exit_code = 1
    redacted_argv = []
    error = ""
    git_before = unavailable_git_context("not captured")
    git_after = unavailable_git_context("not captured")

    try:
        if worker_cwd.exists():
            git_before = git_context(worker_cwd)
        codex_bin, worker_cwd, codex_home = worker_preflight(args)
        argv = [
            codex_bin,
            "--profile",
            args.codex_profile,
            "--cd",
            str(worker_cwd),
            "exec",
            args.task,
        ]
        redacted_argv = argv[:-1] + ["<redacted-task-prompt>"]
        proc = subprocess.run(
            argv,
            cwd=str(worker_cwd),
            env=worker_env(codex_home),
            text=True,
            capture_output=True,
            timeout=args.timeout,
        )
        stdout = proc.stdout
        stderr = proc.stderr
        exit_code = proc.returncode
    except subprocess.TimeoutExpired as exc:
        stdout = exc.stdout or ""
        stderr = exc.stderr or ""
        exit_code = 124
        error = f"worker timed out after {args.timeout}s"
    except SystemExit as exc:
        exit_code = int(exc.code) if isinstance(exc.code, int) else 1
        error = str(exc)
        stderr = f"{stderr}{error}\n"
    finally:
        ended_at = time.time()
        state = load_state()
        if worker_cwd.exists():
            git_after = git_context(worker_cwd)
        git_changed = git_status_delta(git_before, git_after)
        metadata = {
            "model": args.model,
            "codex_profile": args.codex_profile,
            "codex_home": str(codex_home),
            "profile_output": str(profile_path_for_codex_home(codex_home, args.codex_profile)),
            "cwd": str(worker_cwd),
            "port": int(state.get("port", args.port)),
            "pid": relay_is_running(),
            "started_at": int(started_at),
            "ended_at": int(ended_at),
            "elapsed_seconds": round(ended_at - started_at, 3),
            "argv": redacted_argv,
            "exit_code": exit_code,
            "error": error,
            "relay_log": state.get("log_file", str(LOG_FILE)),
            "tool_denylist": args.tool_denylist,
            "git": {
                "before": git_before,
                "after": git_after,
                "changed_files": git_changed,
            },
        }
        write_worker_text(run_dir / "stdout.txt", stdout)
        write_worker_text(run_dir / "stderr.txt", stderr)
        write_worker_text(run_dir / "exit_code.txt", f"{exit_code}\n")
        write_json(run_dir / "metadata.json", metadata)
        summary = worker_summary(metadata, run_dir)
        write_worker_text(run_dir / "summary.txt", summary)
        print(summary, end="")
    return exit_code


def logs(args):
    if not LOG_FILE.exists():
        print(f"log not found: {LOG_FILE}")
        return 1
    lines = LOG_FILE.read_text(encoding="utf-8", errors="replace").splitlines()
    for line in lines[-args.lines:]:
        print(line)
    return 0


def add_common_start_args(parser):
    parser.add_argument("--port", type=int, default=DEFAULT_PORT)
    parser.add_argument("--upstream", default=DEFAULT_UPSTREAM)
    parser.add_argument("--model", default=DEFAULT_MODEL)
    parser.add_argument("--jwt-ttl-seconds", type=int, default=3600)
    parser.add_argument("--refresh-margin-seconds", type=int, default=DEFAULT_REFRESH_MARGIN_SECONDS)
    parser.add_argument("--tool-denylist", default=DEFAULT_TOOL_DENYLIST)
    parser.add_argument("--history-store", choices=["memory", "disk"], default="disk")
    parser.add_argument("--model-map", default="")
    parser.add_argument("--upstream-extra-params", default="")
    parser.add_argument("--drop-upstream-params", default="")
    parser.add_argument("--log-level", default="codex_relay=debug")


def main():
    parser = argparse.ArgumentParser(
        description="Manage a local codex-relay instance for Z.ai GLM-5.2."
    )
    sub = parser.add_subparsers(dest="command", required=True)

    p = sub.add_parser("install-relay", help="Install codex-relay into work/.venv")
    p.add_argument("--python", default=os.environ.get("GLM_RELAY_PYTHON", ""))
    p.add_argument(
        "--source",
        choices=["auto", "pypi", "vendored"],
        default="auto",
        help="Install codex-relay from vendored source when possible, or PyPI prebuilt wheels",
    )
    p.set_defaults(func=install_relay)

    p = sub.add_parser("start", help="Start codex-relay with a fresh Z.ai JWT")
    add_common_start_args(p)
    p.add_argument("--restart", action="store_true")
    p.set_defaults(func=start_relay)

    p = sub.add_parser("restart", help="Restart codex-relay with a fresh Z.ai JWT")
    add_common_start_args(p)
    p.set_defaults(func=lambda args: (stop_relay(), start_relay(args)))
    p.set_defaults(restart=True)

    p = sub.add_parser("refresh", help="Restart relay only when JWT is near expiry")
    add_common_start_args(p)
    p.set_defaults(func=restart_if_needed)

    p = sub.add_parser("serve", help="Run a foreground supervisor that refreshes JWTs")
    add_common_start_args(p)
    p.add_argument("--check-interval-seconds", type=int, default=60)
    p.set_defaults(func=serve)

    p = sub.add_parser("stop", help="Stop codex-relay")
    p.set_defaults(func=lambda _args: print("stopped" if stop_relay() else "not running"))

    p = sub.add_parser("status", help="Show relay status")
    p.set_defaults(func=status)

    p = sub.add_parser("health", help="Call local /v1/models")
    p.add_argument("--port", type=int, default=DEFAULT_PORT)
    p.add_argument("--timeout", type=float, default=5.0)
    p.set_defaults(func=health)

    p = sub.add_parser("live-smoke", help="Run a small live GLM end-to-end smoke test")
    add_common_start_args(p)
    p.add_argument("--timeout", type=float, default=60.0)
    p.add_argument(
        "--include-tool-call",
        action="store_true",
        help="Also ask GLM to return a normal exec_command tool call",
    )
    p.add_argument(
        "--keep-running",
        action="store_true",
        help="Leave a relay started by the smoke running after the check",
    )
    p.set_defaults(func=live_smoke)

    p = sub.add_parser("run-worker", help="Run one bounded Codex task through GLM-5.2")
    add_common_start_args(p)
    p.add_argument("task", help="Bounded worker task prompt for Codex exec")
    p.add_argument("--label", default="", help="Short label for the worker artifact directory")
    p.add_argument("--cwd", default=str(ROOT), help="Working directory for the Codex worker")
    p.add_argument("--timeout", type=float, default=900.0)
    p.add_argument("--codex-profile", default=DEFAULT_CODEX_PROFILE)
    p.add_argument("--codex-home", default=os.environ.get("CODEX_HOME", DEFAULT_CODEX_HOME))
    p.set_defaults(func=run_worker)

    p = sub.add_parser("review-worker", help="Review a GLM worker artifact bundle")
    p.add_argument("target", nargs="?", default="latest", help="Worker run name, path, or latest")
    p.add_argument("--json", action="store_true", dest="json_output", help="Emit a machine-readable summary")
    p.add_argument("--stdout-lines", type=int, default=DEFAULT_REVIEW_TAIL_LINES)
    p.add_argument("--stderr-lines", type=int, default=DEFAULT_REVIEW_TAIL_LINES)
    p.set_defaults(func=review_worker)

    p = sub.add_parser("logs", help="Show recent relay logs")
    p.add_argument("--lines", type=int, default=80)
    p.set_defaults(func=logs)

    p = sub.add_parser("write-profile", help="Write ~/.codex/glm52-relay.config.toml")
    p.add_argument("--output", default="~/.codex/glm52-relay.config.toml")
    p.add_argument("--port", type=int, default=DEFAULT_PORT)
    p.add_argument("--model", default=DEFAULT_MODEL)
    p.set_defaults(func=write_profile)

    args = parser.parse_args()
    result = args.func(args)
    if isinstance(result, int):
        raise SystemExit(result)


if __name__ == "__main__":
    main()
