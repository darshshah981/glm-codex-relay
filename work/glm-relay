def trace_files_in_dir(trace_dir):
    if not trace_dir or not Path(trace_dir).exists():
        return []
    return sorted(Path(trace_dir).glob("*.jsonl"), key=lambda path: (path.stat().st_mtime, path.name))


def resolve_trace_target(target):
    target = target or "latest"
    worker_run_dir = None
    trace_dir = None
    explicit_file = None

    if target == "latest":
        worker_runs = worker_run_dirs()
        if worker_runs:
            worker_run_dir = worker_runs[-1]
            trace_dir = trace_runs_root() / trace_run_id_for_worker_dir(worker_run_dir)
        else:
            runs = trace_run_dirs()
            if runs:
                trace_dir = runs[-1]
        if worker_run_dir is None and trace_dir is None:
            raise SystemExit(f"no worker runs or traces found under {WORKER_RUNS} or {trace_runs_root()}")
    else:
        explicit = Path(target).expanduser()
        if explicit.exists() and explicit.is_file():
            explicit_file = explicit.resolve()
        elif explicit.exists() and explicit.is_dir():
            if (explicit / "metadata.json").exists() or (explicit / "prompt.txt").exists():
                worker_run_dir = explicit.resolve()
                trace_dir = trace_runs_root() / trace_run_id_for_worker_dir(worker_run_dir)
            else:
                trace_dir = explicit.resolve()
        else:
            try:
                worker_run_dir = resolve_worker_run(target)
                trace_dir = trace_runs_root() / trace_run_id_for_worker_dir(worker_run_dir)
            except SystemExit:
                candidate = trace_runs_root() / target
                if candidate.exists() and candidate.is_dir():
                    trace_dir = candidate
                else:
                    raise SystemExit(f"trace target not found: {target}")

    trace_files = [explicit_file] if explicit_file else trace_files_in_dir(trace_dir)
    return {
        "target": target,
        "worker_run_dir": worker_run_dir,
        "trace_dir": trace_dir,
        "trace_files": trace_files,
    }


def load_trace_events(trace_files):
    events = []
    warnings = []
    for path in trace_files:
        try:
            lines = path.read_text(encoding="utf-8", errors="replace").splitlines()
        except Exception as exc:
            warnings.append(f"cannot read trace file {path}: {exc}")
            continue
        for lineno, line in enumerate(lines, start=1):
            if not line.strip():
                continue
            try:
                event = json.loads(line)
            except json.JSONDecodeError as exc:
                warnings.append(f"malformed JSONL in {path.name}:{lineno}: {exc}")
                continue
            if isinstance(event, dict):
                event["_trace_file"] = str(path)
                events.append(event)
            else:
                warnings.append(f"unexpected trace line in {path.name}:{lineno}: expected object")
    events.sort(key=lambda event: (
        event.get("ts_unix_ms", 0),
        event.get("trace_id", ""),
        event.get("seq", 0),
    ))
    return events, warnings


def grouped_trace_events(events):
    groups = []
    by_id = {}
    for event in events:
        trace_id = event.get("trace_id") or "unknown"
        if trace_id not in by_id:
            by_id[trace_id] = []
            groups.append((trace_id, by_id[trace_id]))
        by_id[trace_id].append(event)
    return groups


def preview_text(text, limit=DEFAULT_TRACE_TEXT_CHARS, full=False):
    text = as_text(text)
    if full or len(text) <= limit:
        return text
    return f"{text[:limit]}... [truncated {len(text) - limit} chars]"


def summary_text(summary, full=False, limit=DEFAULT_TRACE_TEXT_CHARS):
    if not isinstance(summary, dict):
        return ""
    text = summary.get("preview", "")
    chars = summary.get("chars")
    truncated = summary.get("truncated")
    rendered = preview_text(text, limit=limit, full=full)
    if truncated and not full and chars:
        return f"{rendered} [trace preview of {chars} chars]"
    return rendered


def content_summary_text(content, full=False):
    if not isinstance(content, dict):
        return ""
    kind = content.get("kind")
    if kind == "text":
        return summary_text(content.get("text"), full=full)
    if kind == "parts":
        parts = []
        for part in content.get("parts", []):
            part_text = summary_text(part.get("text"), full=full)
            if part_text:
                parts.append(part_text)
        return "\n".join(parts)
    return f"<{kind or 'unknown content'}>"


def request_input_lines(input_summary, full=False):
    if not isinstance(input_summary, dict):
        return []
    if input_summary.get("kind") == "text":
        text = summary_text(input_summary.get("text"), full=full)
        return [text] if text else []
    lines = []
    for item in input_summary.get("items", []):
        role = item.get("role") or item.get("type") or "input"
        text = content_summary_text(item.get("content"), full=full)
        if text:
            lines.append(f"{role}: {text}")
        elif item.get("call_id"):
            lines.append(f"{role}: tool result call_id={item.get('call_id')}")
    return lines


def worker_prompt_for_trace(worker_run_dir, warnings):
    if not worker_run_dir:
        return ""
    return read_artifact_text(Path(worker_run_dir) / "prompt.txt", warnings)


def render_trace_turn(trace_id, events, full_prompts=False):
    lines = [f"turn {trace_id}"]
    request_data = next((event.get("data", {}) for event in events if event.get("event") == "codex.request"), {})
    upstream_data = next((event.get("data", {}) for event in events if event.get("event") == "relay.upstream_request"), {})

    if request_data:
        tools = request_data.get("tool_names") or []
        tool_suffix = f" tools={len(tools)}"
        if tools:
            tool_suffix += f" [{', '.join(tools[:8])}{'...' if len(tools) > 8 else ''}]"
        lines.append(
            f"codex -> glm: model={request_data.get('model', 'unknown')} "
            f"stream={request_data.get('stream', False)}{tool_suffix}"
        )
        instructions = summary_text(request_data.get("instructions") or request_data.get("system"), full=full_prompts)
        if instructions:
            lines.append("system/instructions:")
            lines.append(indent_block(instructions))
        input_lines = request_input_lines(request_data.get("input"), full=full_prompts)
        if input_lines:
            lines.append("input:")
            lines.extend(indent_block(line) for line in input_lines)

    if upstream_data and full_prompts:
        lines.append("translated chat messages:")
        for message in upstream_data.get("messages", []):
            role = message.get("role", "message")
            text = content_summary_text(message.get("content"), full=True)
            if text:
                lines.append(indent_block(f"{role}: {text}"))

    reasoning = []
    assistant = []
    tool_deltas = {}
    usage = None
    completed = None
    failed = None

    for event in events:
        name = event.get("event")
        data = event.get("data", {})
        if name == "glm.reasoning.delta":
            reasoning.append(data.get("text", ""))
        elif name == "glm.text.delta":
            assistant.append(data.get("text", ""))
        elif name == "glm.tool_call.delta":
            index = data.get("index", 0)
            entry = tool_deltas.setdefault(index, {"name": "", "id": "", "arguments": ""})
            if data.get("id"):
                entry["id"] = data["id"]
            if data.get("name"):
                entry["name"] = data["name"]
            if data.get("arguments_delta"):
                entry["arguments"] += data["arguments_delta"]
        elif name == "glm.usage":
            usage = data.get("usage", data)
        elif name == "response.completed":
            completed = data
            usage = data.get("usage", usage)
        elif name in {"glm.failed", "relay.failed", "response.failed"}:
            failed = data

    if reasoning:
        lines.append("thinking:")
        lines.append(indent_block(preview_text("".join(reasoning), full=full_prompts)))
    if assistant:
        lines.append("assistant:")
        lines.append(indent_block(preview_text("".join(assistant), full=full_prompts)))
    if tool_deltas:
        lines.append("tool calls:")
        for index, call in sorted(tool_deltas.items()):
            name = call.get("name") or "unknown"
            call_id = call.get("id") or ""
            args = preview_text(call.get("arguments", ""), limit=500, full=full_prompts)
            lines.append(indent_block(f"- index={index} name={name} call_id={call_id} arguments={args}"))

    if failed:
        lines.append(f"status: failed code={failed.get('code', 'unknown')} message={failed.get('message', '')}")
    elif completed:
        lines.append(
            f"status: completed response_id={completed.get('id', '')} "
            f"output_items={completed.get('output_count', 'unknown')}"
        )
    if usage:
        lines.append(
            "usage: "
            f"input={usage.get('input_tokens', usage.get('prompt_tokens', 'unknown'))} "
            f"output={usage.get('output_tokens', usage.get('completion_tokens', 'unknown'))} "
            f"total={usage.get('total_tokens', 'unknown')}"
        )

    return "\n".join(lines)


def indent_block(text):
    return "\n".join(f"  {line}" for line in as_text(text).splitlines() or [""])


def format_trace_thread(target_info, events, warnings, full_prompts=False):
    lines = []
    worker_run_dir = target_info.get("worker_run_dir")
    trace_dir = target_info.get("trace_dir")
    trace_files = target_info.get("trace_files") or []

    lines.append(f"trace thread: {target_info.get('target')}")
    if worker_run_dir:
        lines.append(f"worker_artifacts={worker_run_dir}")
    if trace_dir:
        lines.append(f"trace_dir={trace_dir}")
    if trace_files:
        lines.append(f"trace_files={len(trace_files)}")

    prompt_warnings = []
    prompt = worker_prompt_for_trace(worker_run_dir, prompt_warnings)
    warnings.extend(prompt_warnings)
    if prompt:
        lines.append("worker prompt:")
        lines.append(indent_block(preview_text(prompt, full=full_prompts)))

    if not events:
        lines.append("no trace events found for this target")
    else:
        for trace_id, group in grouped_trace_events(events):
            lines.append("")
            lines.append(render_trace_turn(trace_id, group, full_prompts=full_prompts))

    if warnings:
        lines.append("")
        lines.append("warnings:")
        lines.extend(f"  - {warning}" for warning in warnings)
    lines.append("")
    return "\n".join(lines)


def trace_raw_text(trace_files):
    chunks = []
    for path in trace_files:
        chunks.append(path.read_text(encoding="utf-8", errors="replace"))
    return "".join(chunks)


def read_new_trace_lines(path, offset):
    with Path(path).open("r", encoding="utf-8", errors="replace") as handle:
        handle.seek(offset)
        data = handle.read()
        return data.splitlines(), handle.tell()


def format_single_trace_event(event, full_prompts=False):
    name = event.get("event", "event")
    data = event.get("data", {})
    if name == "glm.reasoning.delta":
        return f"thinking: {preview_text(data.get('text', ''), limit=300, full=full_prompts)}"
    if name == "glm.text.delta":
        return f"assistant: {preview_text(data.get('text', ''), limit=300, full=full_prompts)}"
    if name == "glm.tool_call.delta":
        return f"tool delta: index={data.get('index', 0)} name={data.get('name', '')} args={preview_text(data.get('arguments_delta', ''), limit=200, full=full_prompts)}"
    if name == "response.completed":
        return f"completed: response_id={data.get('id', '')}"
    if name in {"glm.failed", "relay.failed", "response.failed"}:
        return f"failed: code={data.get('code', 'unknown')} message={data.get('message', '')}"
    return f"{name}: seq={event.get('seq', '')}"


def follow_traces(args):
    offsets = {}
    print("following traces; press Ctrl-C to stop")
    try:
        while True:
            target_info = resolve_trace_target(args.target)
            for path in target_info["trace_files"]:
                offset = offsets.get(path, 0)
                lines, new_offset = read_new_trace_lines(path, offset)
                offsets[path] = new_offset
                for line in lines:
                    if args.raw:
                        print(line)
                        continue
                    try:
                        event = json.loads(line)
                    except json.JSONDecodeError:
                        print(f"warning: malformed trace line in {path.name}")
                        continue
                    print(format_single_trace_event(event, full_prompts=args.full_prompts))
            time.sleep(args.poll_seconds)
    except KeyboardInterrupt:
        print("\nstopped following traces")
    return 0


def traces(args):
    if args.follow:
        return follow_traces(args)
    target_info = resolve_trace_target(args.target)
    if args.raw:
        if not target_info["trace_files"]:
            raise SystemExit(f"no trace files found for target: {args.target}")
        print(trace_raw_text(target_info["trace_files"]), end="")
        return 0
    events, warnings = load_trace_events(target_info["trace_files"])
    print(format_trace_thread(target_info, events, warnings, full_prompts=args.full_prompts), end="")
    return 0


def worker_env(codex_home):
    env = os.environ.copy()
    env["CODEX_HOME"] = str(codex_home)
    scrub_relay_secret_env(env)
    return env


def scrub_relay_secret_env(env):
    for key in list(env):
        if key.startswith("ZAI_") or key.startswith("CODEX_RELAY_"):
            env.pop(key, None)
    return env


def codex_home_path(value):
    return Path(value).expanduser().resolve()


def profile_path_for_codex_home(codex_home, profile_name):
    return codex_home / f"{profile_name}.config.toml"


def pid_from_file():
    try:
        return int(PID_FILE.read_text(encoding="utf-8").strip())
    except Exception:
        return None


def process_alive(pid):
    if not pid:
        return False
    try:
        os.kill(pid, 0)
        return True
    except ProcessLookupError:
        return False
    except PermissionError:
        return True


def relay_is_running():
    pid = pid_from_file()
    return pid if process_alive(pid) else None


def stop_relay():
    pid = relay_is_running()
    if not pid:
        PID_FILE.unlink(missing_ok=True)
        return False
    os.kill(pid, signal.SIGTERM)
    deadline = time.time() + 10
    while time.time() < deadline:
        if not process_alive(pid):
            break
        time.sleep(0.2)
    if process_alive(pid):
        os.kill(pid, signal.SIGKILL)
    PID_FILE.unlink(missing_ok=True)
    return True


def start_relay(args):
    ensure_dirs()
    TRACE_DIR.mkdir(parents=True, exist_ok=True)
    if relay_is_running():
        if args.restart:
            stop_relay()
        else:
            raise SystemExit(f"relay already running with pid {pid_from_file()}")

    raw_key = os.environ.get("ZAI_RAW_KEY", "")
    token, exp = generate_zai_jwt(raw_key, ttl_seconds=args.jwt_ttl_seconds)
    relay_bin = find_relay_binary()

    env = scrub_relay_secret_env(os.environ.copy())
    env["CODEX_RELAY_UPSTREAM"] = args.upstream
    env["CODEX_RELAY_API_KEY"] = token
    env["CODEX_RELAY_PORT"] = str(args.port)
    env["CODEX_RELAY_TOOL_DENYLIST"] = args.tool_denylist
    env["CODEX_RELAY_HISTORY_STORE"] = args.history_store
    env["CODEX_RELAY_HISTORY_DIR"] = str(STATE / "history")
    env["CODEX_RELAY_TRACE_DIR"] = str(TRACE_DIR)
    env["CODEX_RELAY_ACTIVE_WORKER_FILE"] = str(ACTIVE_WORKER_FILE)
    env["RUST_LOG"] = args.log_level

    if args.model_map:
        env["CODEX_RELAY_MODEL_MAP"] = args.model_map
    if args.upstream_extra_params:
        env["CODEX_RELAY_UPSTREAM_EXTRA_PARAMS"] = args.upstream_extra_params
    if args.drop_upstream_params:
        env["CODEX_RELAY_DROP_PARAMS"] = args.drop_upstream_params

    log = LOG_FILE.open("ab")
    log.write(f"\n--- glm-relay start {time.strftime('%Y-%m-%dT%H:%M:%SZ', time.gmtime())} ---\n".encode())
    log.flush()
    proc = subprocess.Popen(
        [relay_bin],
        cwd=str(ROOT),
        env=env,
        stdout=log,
        stderr=subprocess.STDOUT,
        start_new_session=True,
    )
    PID_FILE.write_text(str(proc.pid), encoding="utf-8")
    save_state({
        "pid": proc.pid,
        "port": args.port,
        "upstream": args.upstream,
        "model": args.model,
        "jwt_expires_at": exp,
        "jwt_refresh_margin_seconds": args.refresh_margin_seconds,
        "relay_bin": relay_bin,
        "log_file": str(LOG_FILE),
        "trace_dir": str(TRACE_DIR),
        "active_worker_file": str(ACTIVE_WORKER_FILE),
        "started_at": int(time.time()),
        "tool_denylist": args.tool_denylist,
        "history_store": args.history_store,
        "model_map": args.model_map,
        "upstream_extra_params": args.upstream_extra_params,
        "drop_upstream_params": args.drop_upstream_params,
    })
    print(f"started codex-relay pid={proc.pid} on http://127.0.0.1:{args.port}/v1")
    print(f"jwt expires at {time.strftime('%Y-%m-%dT%H:%M:%SZ', time.gmtime(exp))}")


def restart_if_needed(args):
    state = load_state()
    pid = relay_is_running()
    if not pid:
        print("relay not running; starting")
        start_relay(args)
        return
    mismatches = relay_state_mismatches(state, args)
    if mismatches:
        print(f"relay settings changed ({', '.join(mismatches)}); restarting relay")
        stop_relay()
        start_relay(args)
        return
    exp = int(state.get("jwt_expires_at", 0))
    margin = int(state.get("jwt_refresh_margin_seconds", args.refresh_margin_seconds))
    if exp and time.time() < exp - margin:
        remaining = int(exp - time.time())
        print(f"relay ok pid={pid}; jwt has {remaining}s remaining")
        return
    print("jwt near expiry or unknown; restarting relay with fresh token")
    stop_relay()
    start_relay(args)


def relay_state_mismatches(state, args):
    expected = {
        "port": args.port,
        "upstream": args.upstream,
        "model": args.model,
        "tool_denylist": args.tool_denylist,
        "history_store": args.history_store,
        "model_map": args.model_map,
        "upstream_extra_params": args.upstream_extra_params,
        "drop_upstream_params": args.drop_upstream_params,
    }
    mismatches = []
    for key, expected_value in expected.items():
        actual = state.get(key)
        if actual is None and expected_value == "":
            actual = ""
        if actual != expected_value:
            mismatches.append(key)
    return mismatches


def serve(args):
    print("serving GLM relay; press Ctrl-C to stop")
    try:
        while True:
            restart_if_needed(args)
            time.sleep(args.check_interval_seconds)
    except KeyboardInterrupt:
        print("\nshutting down relay")
        stop_relay()


def status(_args):
