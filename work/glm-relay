def git_command(cwd, *args):
    return subprocess.run(
        ["git", "-C", str(cwd), *args],
        text=True,
        capture_output=True,
        timeout=GIT_COMMAND_TIMEOUT_SECONDS,
    )


def unavailable_git_context(reason):
    return {
        "available": False,
        "reason": as_text(reason).strip()[:500],
        "repo_root": "",
        "head": "",
        "status": [],
    }


def parse_git_status_lines(text):
    entries = []
    for line in as_text(text).splitlines():
        if not line:
            continue
        status = line[:2].strip() or line[:2]
        path = line[3:] if len(line) > 3 else ""
        entries.append({"status": status, "path": path})
    return entries


def git_context(cwd):
    cwd = Path(cwd)
    if not cwd.exists() or not cwd.is_dir():
        return unavailable_git_context(f"cwd is not a directory: {cwd}")

    try:
        root = git_command(cwd, "rev-parse", "--show-toplevel")
        if root.returncode != 0:
            return unavailable_git_context(root.stderr or root.stdout or "not a git repository")
        head = git_command(cwd, "rev-parse", "HEAD")
        status = git_command(cwd, "status", "--porcelain=v1")
    except FileNotFoundError:
        return unavailable_git_context("git binary not found")
    except subprocess.TimeoutExpired as exc:
        return unavailable_git_context(f"git command timed out after {exc.timeout}s")
    except Exception as exc:
        return unavailable_git_context(exc)

    if head.returncode != 0:
        return unavailable_git_context(head.stderr or head.stdout or "cannot resolve git HEAD")
    if status.returncode != 0:
        return unavailable_git_context(status.stderr or status.stdout or "cannot read git status")

    return {
        "available": True,
        "reason": "",
        "repo_root": root.stdout.strip(),
        "head": head.stdout.strip(),
        "status": parse_git_status_lines(status.stdout),
    }


def git_status_map(snapshot):
    return {
        entry.get("path", ""): entry.get("status", "")
        for entry in snapshot.get("status", [])
        if entry.get("path")
    }


def git_status_delta(before, after):
    if not before.get("available") or not after.get("available"):
        return []

    before_status = git_status_map(before)
    after_status = git_status_map(after)
    changed = []
    for path in sorted(set(before_status) | set(after_status)):
        before_value = before_status.get(path, "")
        after_value = after_status.get(path, "")
        if before_value == after_value and after_value:
            change = "preexisting"
        elif before_value and not after_value:
            change = "cleaned"
        elif after_value and not before_value:
            change = "new"
        else:
            change = "changed"
        changed.append({
            "path": path,
            "before_status": before_value,
            "after_status": after_value,
            "change": change,
        })
    return changed


